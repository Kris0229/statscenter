# Backend environment variables. Copy to `.env` and adjust.
# In production/demo these are set via the platform (Render/Supabase); no secrets in git.

# --- Database ---
# Local Docker default:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/statscenter
# Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres.xxxx:PASSWORD@aws-...pooler.supabase.com:5432/postgres

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- CORS (comma-separated origins, or * for dev) ---
CORS_ORIGINS=http://localhost:5173

# --- Storage backend: local | supabase | s3 (s3 not implemented yet) ---
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=media
MEDIA_LOCAL_DIR=media
MEDIA_MAX_BYTES=8388608

# --- One-off bootstrap for super_admin (used by app.db.bootstrap_superadmin) ---
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
